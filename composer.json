{
    "name": "daika7ana/ecolet-php-sdk",
    "description": "Typed PHP SDK for the Ecolet Courier API.",
    "license": "GPL-3.0-or-later",
    "autoload": {
        "psr-4": {
            "Daika7ana\\Ecolet\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Daika7ana\\Ecolet\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Dan-Radu Pana",
            "email": "11703528+daika7ana@users.noreply.github.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "guzzlehttp/guzzle": "^7.0",
        "symfony/http-foundation": "^5.0 || ^6.0 || ^7.0",
        "psr/http-message": "^1.0 || ^2.0",
        "psr/http-factory": "^1.0",
        "psr/http-client": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "laravel/pint": "^1.29",
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "pint": "@php vendor/bin/pint --test",
        "stan": "@php vendor/bin/phpstan --no-progress",
        "test": "@php vendor/bin/phpunit",
        "test:unit": "@php vendor/bin/phpunit tests/Unit",
        "ci": [
            "@pint",
            "@stan",
            "@test:unit"
        ]
    }
}
